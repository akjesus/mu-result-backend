extends baseEmail
block content
    p Hi #{firstName},
    p Forgot Password?
    table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
        tbody
            tr
                td(align='left')
                    table(role='presentation', border='0', cellpadding='0', cellspacing='0')
                        tbody
                            tr
                                td
                                  Reset Your Password reset code = #{code}
    p If you didn't submit any request, please ignore this email!
    p Enter this code in the next page to reset your password
    p Maduka University ICT Unit